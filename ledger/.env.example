# Ledger service environment example
# Copy to .env and set values for your node.

PAYOUT_INTERVAL_MINUTES=10
PAYOUT_DECIMALS=8

# Reward mode: blocks | fixed
REWARD_MODE=blocks
BLOCK_REWARD_BTC=1.87500000
FIXED_REWARD_BTC=
ENABLE_BLOCK_EVENT_REWARDS=true
MATURITY_WINDOW_MINUTES=200

# Reward source endpoints
POOL_REWARD_URL=
POOL_API_BASE_URL=
POOL_API_KEY=change-me
BLOCK_REWARD_BATCH_URL=http://127.0.0.1:8080/v1/az/blocks/rewards
BLOCK_REWARD_BATCH_TIMEOUT_SECONDS=10
DEFER_ON_ZERO_MATURED_REWARD=true

# Translator endpoints
TRANSLATOR_BLOCKS_FOUND_URL=http://127.0.0.1:8080/v1/translator/blocks-found
TRANSLATOR_BLOCKS_FOUND_TIMEOUT_SECONDS=10
TRANSLATOR_BLOCKS_FOUND_LIMIT=100
TRANSLATOR_BLOCKS_FOUND_CANDIDATE_WINDOW_SECONDS=30
TRANSLATOR_BLOCKS_FOUND_CANDIDATE_LIMIT=5
TRANSLATOR_METRICS_URL=http://127.0.0.1:9092/metrics
TRANSLATOR_CHANNELS_URL=http://127.0.0.1:8080/v1/translator/upstream/channels
TRANSLATOR_DOWNSTREAMS_URL=http://127.0.0.1:8080/v1/translator/downstreams
TRANSLATOR_BEARER_TOKEN=change-me

# Hooks
ENABLE_STARTUP_RECONCILIATION_HOOK=false
ENABLE_BLOCK_EVENT_REPLAY_HOOK=false
ENABLE_REWARD_REFETCH_HOOK=false
ENABLE_SETTLEMENT_REPLAY_HOOK=false

# Runtime paths
PAYOUT_AUDIT_LOG_PATH=./logs/payout_audit.jsonl
DB_PATH=./payouts.db

# Background scheduler
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=60

# Safety switch
DRY_RUN=true
