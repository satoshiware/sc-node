# =============================================================================
# AZPool Backend Environment Configuration
# =============================================================================
# Important:
# • Carefully review and fill out this file before running the azpool-backend-setup.sh script.
#   It controls all critical settings for the installation.
#
# • All SHA256 hashes of tarball downloads are automatically verified.
#
# • After successful setup, remember to forward these ports on your router/firewall:
#     - SSH          : 22/tcp
#     - AZCoin P2P   : AZCOIN_P2P_PORT/tcp
#     - WireGuard    : WG_PORT/udp
# =============================================================================

# =============================================================================
# AZPool Backend Environment Configuration
# =============================================================================
# Important:
#   • Carefully review and fill out azpool-backend.env before running.
#     It contains download URLs, SHA256 checksums, ports, FIDO2 keys,
#     hostname, and other critical settings.
#   • All tarball downloads are verified with SHA256 for security.
#
# IMPORTANT: After setup, forward these ports on your router/firewall:
#   - SSH               : 22/tcp
#   - AZCoin P2P        : AZCOIN_P2P_PORT/tcp
#   - WireGuard VPN     : WG_PORT/udp
# =============================================================================

# === MACHINE SETTINGS ===
AZPOOL_HOSTNAME="azpool-backend"

# === STATIC IP (optional but recommended) ===
# Uncomment and fill these if you want a fixed IP.
# The system will use DHCP if STATIC_IP is empty.
# STATIC_IP="192.168.1.100"
# STATIC_GATEWAY="192.168.1.1"
# STATIC_DNS="1.1.1.1,8.8.8.8"

# === SATOSHI FIDO2 KEYS ===
# First key is required. Up to 4 total. Comment is optional but recommended
SATOSHI_FIDO2_KEY1="sk-ecdsa-sha2-nistp256@openssh.com AAA...your-primary-key-here... # primary-yubikey"
SATOSHI_FIDO2_KEY2="sk-ecdsa-sha2-nistp256@openssh.com AAA...your-backup-key-1-here... # backup-yubikey"
SATOSHI_FIDO2_KEY3="sk-ecdsa-sha2-nistp256@openssh.com AAA...your-backup-key-2-here... # backup-2025"
SATOSHI_FIDO2_KEY4=""   # leave empty if not used

# === WIREGUARD ===
WG_PORT="51820"
# Server tunnel IP is hardcoded to 10.8.0.1/24 (standard)

# === AZCOIN NODE ===
AZCOIN_TARBALL_URL="https://yourdomain.com/releases/azcoin-latest.tar"
AZCOIN_TARBALL_SHA256="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

AZCOIN_DBCACHE="16384"
AZCOIN_MAXMEMPOOL="1024"
AZCOIN_P2P_PORT="19333"
AZCOIN_IP_UPDATER_CRON_ENABLE="enable"
AZCOIN_SEEDNODE_DNS="seed.azcoin.example.com"

# === TEMPLAR (SV2 Template Provider) ===
TEMPLATE_PROVIDER_TARBALL_URL="https://yourdomain.com/releases/templar-latest.tar"
TEMPLATE_PROVIDER_TARBALL_SHA256="yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# === PAYOUTS ENGINE ===
PAYOUT_ENGINE_TARBALL_URL="https://yourdomain.com/releases/payouts-latest.tar"
PAYOUT_ENGINE_TARBALL_SHA256="zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz"