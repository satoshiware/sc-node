# Testing-only bare-metal example for Ubuntu/Debian + systemd.
# This file is not a hardened production configuration.

APP_ENV=dev
AUTH_MODE=dev_token
AZ_API_DEV_TOKEN=change-me
API_V1_PREFIX=/v1
LOG_LEVEL=INFO

AZ_RPC_URL=http://127.0.0.1:19332
AZ_RPC_USER=azrpc
AZ_RPC_PASSWORD=change-me
AZ_RPC_TIMEOUT_SECONDS=5
AZ_EXPECTED_CHAIN=micro

BTC_RPC_URL=http://127.0.0.1:8332
BTC_RPC_USER=bitcoinrpc
BTC_RPC_PASSWORD=change-me
BTC_RPC_TIMEOUT_SECONDS=5

# Optional translator observability inputs for this branch.
TRANSLATOR_LOG_PATH=
TRANSLATOR_LOG_DEFAULT_LINES=200
TRANSLATOR_LOG_MAX_LINES=1000
TRANSLATOR_MONITORING_BASE_URL=
TRANSLATOR_MONITORING_TIMEOUT_SECS=3.0
TRANSLATOR_BLOCKS_FOUND_DB_PATH=.data/translator_blocks_found.sqlite3
