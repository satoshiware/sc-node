# =============================================================================
# AZCoin Pool Instance Environment Configuration
# =============================================================================
# Important:
#   • Carefully review and fill out this file before running azpool-backend-setup.sh
#   • It controls all critical settings for the installation.
#   • All SHA256 hashes of tarball downloads are automatically verified.
#   • This file is automatically secured (root:root 600) by the setup script
#     → because it contains the AUTHORITY_SECRET_KEY (shared across all instances)
#
# IMPORTANT: After successful setup, forward these ports on your router/firewall:
#   - SSH:           22/tcp
#   - Translator:    3336/tcp   (V1 miners)
#   - AZCoin Pool:   3337/tcp   (SV2)
# =============================================================================

# === INSTANCE SETTINGS ===
INSTANCE_NAME="pool-instance-01" # Also used as the machine hostname

# === STATIC IP (optional but recommended) ===
# Uncomment and fill these if you want a fixed IP on this instance.
# The system will use DHCP if STATIC_IP is empty.
# STATIC_IP="192.168.1.100"
# STATIC_GATEWAY="192.168.1.1"
# STATIC_DNS="1.1.1.1,8.8.8.8"

# === SATOSHI FIDO2 KEYS ===
# First key is required. Up to 4 total. Comment is optional but recommended for tracking.
SATOSHI_FIDO2_KEY1="sk-ecdsa-sha2-nistp256@openssh.com AAA...your-primary-key-here... # primary-yubikey"
SATOSHI_FIDO2_KEY2="sk-ecdsa-sha2-nistp256@openssh.com AAA...your-backup-key-1-here... # backup-yubikey"
SATOSHI_FIDO2_KEY3="sk-ecdsa-sha2-nistp256@openssh.com AAA...your-backup-key-2-here... # backup-2025"
SATOSHI_FIDO2_KEY4=""   # leave empty if not used

# === WIREGUARD VPN (Client → Backend) ===
WG_SERVER_ENDPOINT="your-backend.example.com:51820"
WG_SERVER_PUBLIC_KEY="YOUR_BACKEND_WIREGUARD_PUBLIC_KEY_HERE"
# WireGuard client address will be assigned (manually) post-install

# ================ POOL =================
# Download SRI Stratum V2 Pool (it will be automatically downloaded + verified)
POOL_TAR_URL="https://yourdomain.com/releases/pool_sv2-latest.tar.gz"
POOL_TAR_SHA256="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Template Provider direct connection (not via WireGuard) on backend using the Noise protocol.
TEMPLATE_PROVIDER_ADDR="your-backend-public-ip:19442"
TEMPLATE_PROVIDER_PUBKEY="...................................................."

# AUTHORITY SECRET KEY
# This secret key is identical across ALL pool instances.
#   • On the FIRST instance: Leave this line commented out (script will generate).
#   • On subsequent instances: Uncomment and paste the exact same key from the first instance.
#     → Location: /etc/azpool/azpool.toml
# CRITICAL! Transfer securely. After successful setup, remove all traces of this key.
#AUTHORITY_SECRET_KEY="mkDLTBBRxdBv998612qipDYoTK3YUrqLe8uWw7gu3iXbSrn2n"

# ================ TRANSLATOR =================
TRANSLATOR_TAR_URL="https://yourdomain.com/releases/translator_sv2-latest.tar.gz"
TRANSLATOR_TAR_SHA256="yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# ============ AZCOIN RPC CREDENTIALS (for coinbase updater) ===============
# These credentials allow the coinbase updater to connect to the AZCoin node
# To obtain, on the BACKEND server run: cat /home/azcoin/coinbase-rpcpassword
# Security Note:
#   • Copy this password carefully
#   • This password is only for the restricted 'coinbase updater' RPC user
AZCOIN_RPC_USER="coinbase"
AZCOIN_RPC_PASS="your-secure-coinbase-rpc-password-here"