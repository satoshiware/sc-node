AZ_RPC_USER=azrpc
AZ_RPC_PASSWORD=azrpc-pass-change-me
AZ_RPC_URL=http://azcoind:19332
AZ_API_DEV_TOKEN=testtoken-123
APP_ENV=dev
AUTH_MODE=dev_token

# Optional: translator log file for /v1/translator/* observability (leave unset to disable reads)
TRANSLATOR_LOG_PATH=
TRANSLATOR_LOG_DEFAULT_LINES=200
TRANSLATOR_LOG_MAX_LINES=1000

# Optional: translator built-in monitoring HTTP base URL for live-state endpoints under /v1/translator/*
# TRANSLATOR_MONITORING_BASE_URL=http://127.0.0.1:5000
# TRANSLATOR_MONITORING_TIMEOUT_SECS=3

# Optional: durable SQLite evidence store for translator blocks_found counter deltas
TRANSLATOR_BLOCKS_FOUND_DB_PATH=.data/translator_blocks_found.sqlite3

# Bitcoin RPC: docker-compose uses cookie auth (no vars needed for same-stack).
# For remote bitcoind, set: BTC_RPC_URL, BTC_RPC_USER, BTC_RPC_PASSWORD
